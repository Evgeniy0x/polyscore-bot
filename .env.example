# PolyScore — Environment Variables
# Copy to .env and fill in production values.
# NEVER commit .env to git.

# ── Telegram ──────────────────────────────────────────────────────────
# Create bot via @BotFather → get token
BOT_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI (OpenRouter) ───────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Polymarket CLOB API ───────────────────────────────────────────────
# Required for REAL trading. Without these, bot runs in demo mode.
# Get from: polymarket.com/settings?tab=builder
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=

# ── Polymarket Trading Wallet ─────────────────────────────────────────
# Private key of the Polygon wallet that SIGNS orders.
# This wallet must hold USDC on Polygon for order execution.
# Format: 0x followed by 64 hex characters
# WARNING: Guard this like a password. Anyone with this key controls the funds.
POLY_PRIVATE_KEY=

# ── Builder Attribution (for builder rewards) ────────────────────────
# Separate from CLOB API keys! Generate at polymarket.com/settings?tab=builder
# Secret and passphrase are shown ONCE — save them immediately.
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=
BUILDER_CODE=polyscore

# ── Relayer API Key (for gasless transactions) ────────────────────────
# Get from: polymarket.com/settings?tab=relayer
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# ── Wallet Encryption ─────────────────────────────────────────────────
# AES-256 key for encrypting user wallet private keys in the database.
# Generate with: python3 -c "import os; print(os.urandom(32).hex())"
# If not set, falls back to a key derived from BOT_TOKEN (dev only, NOT safe for production).
WALLET_ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────────
# Defaults to polyscore.db next to bot.py. Override for cloud deployments.
DB_PATH=polyscore.db
